    "matter-js": "^0.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/matter-js": "^0.19.8",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.10"
  }
}
